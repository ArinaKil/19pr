<UserControl x:Class="Kino_Kilunina.Elements.AfishaItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Kino_Kilunina.Elements"
             mc:Ignorable="d"
             d:DesignHeight="150" d:DesignWidth="380">

    <Border Background="White" CornerRadius="10"
            BorderBrush="#DDDDDD" BorderThickness="1"
            Margin="8" Padding="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="/Images/afisha.png"
                   Width="64" Height="64"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Stretch="Uniform"/>

            <StackPanel Grid.Column="1" Margin="10 0 0 0" VerticalAlignment="Center">
                <TextBlock x:Name="tbName" FontSize="15" FontWeight="SemiBold"
                           Foreground="#1A1A2E" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="tbTime" FontSize="12" Foreground="#555555" Margin="0 4 0 0"/>
                <TextBlock x:Name="tbPrice" FontSize="12" Foreground="#E94560" FontWeight="Bold" Margin="0 2 0 0"/>
                <TextBlock x:Name="tbKinoteatr" FontSize="11" Foreground="#888888" Margin="0 2 0 8"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="btnEdit" Content="Изменить"
                            Width="80" Height="26" FontSize="11"
                            Background="#4A90D9" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnEdit_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnDelete" Content="Удалить"
                            Width="80" Height="26" FontSize="11"
                            Background="#E94560" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Margin="8 0 0 0"
                            Click="btnDelete_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

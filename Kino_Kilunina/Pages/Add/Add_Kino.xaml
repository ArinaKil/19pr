<Page x:Class="Kino_Kilunina.Pages.Add.Add_Kino"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Kino_Kilunina.Pages.Add"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add_Kino">

    <Grid Background="#F4F6F9">
        <Border Background="White" CornerRadius="12"
                BorderBrush="#DDDDDD" BorderThickness="1"
                Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                Padding="28">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.1" Color="Black"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="/Images/cinema.png" Width="64" Height="64"
                       HorizontalAlignment="Center" Margin="0 0 0 12"/>

                <TextBlock x:Name="tbTitle" Text="Добавить кинотеатр"
                           FontSize="17" FontWeight="Bold" Foreground="#1A1A2E"
                           HorizontalAlignment="Center" Margin="0 0 0 20"/>

                <TextBlock Text="Название" FontSize="12" Foreground="#555555" Margin="0 0 0 4"/>
                <TextBox x:Name="tbName" Height="34" FontSize="13"
                         Padding="8 0" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Количество залов" FontSize="12" Foreground="#555555" Margin="0 12 0 4"/>
                <TextBox x:Name="tbCountZal" Height="34" FontSize="13"
                         Padding="8 0" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock Text="Количество мест" FontSize="12" Foreground="#555555" Margin="0 12 0 4"/>
                <TextBox x:Name="tbCount" Height="34" FontSize="13"
                         Padding="8 0" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 24 0 0">
                    <Button Content="Отмена" Width="100" Height="34" FontSize="13"
                            Background="#EEEEEE" Foreground="#333333"
                            BorderThickness="0" Cursor="Hand"
                            Click="btnCancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnSave" Content="Сохранить" Width="120" Height="34" FontSize="13"
                            Background="#4A90D9" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Margin="12 0 0 0"
                            Click="btnSave_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
